  "repository": {
    "type": "git",
    "url": "https://github.com/Vdc-K/macs-protocol"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    ".macs/protocol/dist/",
    "templates/",
    "adapters/",
    "skills/",
    "AGENT-GUIDE.md",
    "MACS-SPEC.md",
    "README.md",
    "SKILL.md"
  ]
}
