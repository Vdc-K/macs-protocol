{
  "name": "macs-protocol",
  "version": "5.3.0",
  "description": "MACS — The Universal Workbench for AI Agents. Cross-framework work coordination via JSONL event sourcing.",
  "type": "module",
  "bin": {
    "macs": "bin/macs.js"
  },
